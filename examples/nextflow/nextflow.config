/*
 * nextflow.config — profiles for running the casetrack example pipeline.
 *
 * Author: Samuel Ahuno <ekwame001@gmail.com>
 * Date:   2026-04-15
 */

manifest {
    name        = 'casetrack-example'
    author      = 'Samuel Ahuno'
    description = 'Demo Nextflow pipeline that registers results via casetrack.'
    mainScript  = 'example_pipeline.nf'
    nextflowVersion = '>=23.04.0'
}

// Default (fallback) params — all overridable on the command line.
params {
    casetrack_manifest   = "${launchDir}/manifest.tsv"
    casetrack_key        = "sample_id"
    casetrack_bin        = "casetrack"
    casetrack_allow_new  = false
    casetrack_extra      = ""
    samples_csv          = "${launchDir}/samples.csv"
}

profiles {

    standard {
        process.executor = 'local'
    }

    slurm {
        process {
            executor = 'slurm'
            queue    = 'componc_cpu'
            clusterOptions = '--account=greenbab --mail-type=END,FAIL --mail-user=ahunos@mskcc.org'
            cpus   = 2
            memory = '8 GB'
            time   = '2h'

            withName: casetrack_append {
                cpus   = 1
                memory = '2 GB'
                time   = '15m'
            }
        }
    }

    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
        apptainer.runOptions = '--bind /data1/greenbab'
        // Override per-process if the casetrack binary lives inside a sif:
        //   process.container = '/data1/greenbab/software/images/casetrack.sif'
    }

    // For the test suite — strips SLURM and uses the local shell.
    test {
        process.executor = 'local'
        process.cpus     = 1
    }
}
